{
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "regions": ["iad"],
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "routes": [
    {
      "src": "^/(?!api).*$",
      "destination": "/index.html",
      "continue": true
    }
  ]
}
